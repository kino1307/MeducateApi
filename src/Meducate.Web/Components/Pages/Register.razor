
@page "/register"
@rendermode InteractiveServer
@inject Meducate.Web.Services.ApiService Api
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS

@using Meducate.Web.Components.Shared;
@using Meducate.Web.Models;

<SeoHead Title="Sign Up Free — Meducate API"
         Description="Create a free Meducate API account to start accessing structured medical data immediately."
         Canonical="https://meducateapi.com/register" />

<div class="container min-vh-100 d-flex justify-content-center pt-5">
    <div class="row w-100 justify-content-center">
        <div class="col-md-6 col-lg-5">

            <h1 class="h3 fw-bold mb-3 text-center">@(_isCreateMode ? "Create account" : "Sign in")</h1>

            @if (_isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>
            }
            else
            {
            <div class="card">
                <div class="card-body">

                    @if (_form is not null && !IsCompleted)
                    {
                        <EditForm FormName="UserRegistrationForm" Model="_form" OnValidSubmit="Submit" class="was-validated">
                            <label for="usernameInput" class="form-label h5">Email address</label>
                            <InputText id="usernameInput" @bind-Value="_form.Username" type="email" class="form-control" required />

                            @* Honeypot field — hidden from real users, bots fill it *@
                            <div style="position: absolute; left: -9999px;" aria-hidden="true">
                                <label for="websiteInput">Website</label>
                                <InputText id="websiteInput" @bind-Value="_form.Website" tabindex="-1" autocomplete="off" />
                            </div>
                            <input type="hidden" name="_form.Timestamp" value="@_form.Timestamp" />

                            <p class="text-muted mt-2 small">We'll send you a link to @(_isCreateMode ? "get started" : "sign in").</p>

                            @if (_isCreateMode)
                            {
                                <div class="form-check mt-3">
                                    <InputCheckbox id="termsCheck" @bind-Value="_form.AcceptedTerms" class="form-check-input" disabled="@(!_hasViewedPrivacy || !_hasViewedTerms)" required />
                                    <label class="form-check-label small" for="termsCheck">
                                        I agree to the
                                        <button type="button" class="btn btn-link p-0 align-baseline small" @onclick="OpenPrivacyModal">Privacy Policy</button>
                                        and
                                        <button type="button" class="btn btn-link p-0 align-baseline small" @onclick="OpenTermsModal">Terms of Service</button>.
                                    </label>
                                </div>
                            }

                            <hr>

                            <div class="d-flex justify-content-end">
                                <SubmitButton Classes="btn-primary" IsLoading="_isSubmitting">Continue</SubmitButton>
                            </div>
                        </EditForm>
                    }

                    @if (IsCompleted)
                    {
                        <div class="text-center py-3">
                            <h5 class="fw-semibold mb-2">Check your email</h5>
                            <p class="text-muted mb-3">
                                We've sent a @(_isCreateMode ? "verification" : "sign-in") link to <strong>@_form?.Username</strong>.<br />
                                Click the link in the email to continue.
                            </p>
                            <div class="alert alert-success" role="alert">
                                You can safely close this page.
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Alert) && !IsCompleted)
                    {
                        <div class="alert @AlertCss mt-3" role="alert">
                            @Alert
                        </div>
                    }

                </div>
            </div>
            }

        </div>
    </div>
</div>

@* Privacy Policy Modal *@
@if (_showPrivacyModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Privacy Policy</h5>
                    <button type="button" class="btn-close" @onclick="ClosePrivacyModal"></button>
                </div>
                <div class="modal-body" id="privacyModalBody" style="overflow-y: auto; max-height: 60vh;">
                    <p class="text-muted">Last updated: 2 March 2026</p>
                    <hr>
                    <h5 class="fw-semibold">Data We Collect</h5>
                    <ul>
                        <li><strong>Email address</strong> &mdash; used for authentication (magic-link sign-in) and service notifications (e.g. rate limit warnings).</li>
                        <li><strong>API usage logs</strong> &mdash; endpoint, HTTP method, status code, query parameters, organisation name, and timestamp. Logged per API request for usage tracking and rate limiting.</li>
                        <li><strong>Cookies</strong> &mdash; we use two functional cookies: an authentication cookie (<code>meducateapi_auth</code>) and a theme preference cookie. Neither is used for tracking or advertising.</li>
                    </ul>
                    <h5 class="fw-semibold mt-4">What We Do Not Collect</h5>
                    <ul>
                        <li>We do not collect IP addresses.</li>
                        <li>We do not use analytics, tracking pixels, or advertising cookies.</li>
                        <li>We do not collect passwords &mdash; authentication is passwordless via email links.</li>
                    </ul>
                    <h5 class="fw-semibold mt-4">Purpose</h5>
                    <p>Data is collected solely to operate the service: authenticate users, enforce rate limits, monitor API usage, and send transactional emails.</p>
                    <h5 class="fw-semibold mt-4">Data Retention</h5>
                    <p>Your data is retained for as long as your account exists. When you delete your account, all associated data (usage logs, API keys, organisation) is permanently deleted.</p>
                    <h5 class="fw-semibold mt-4">Third Parties</h5>
                    <ul>
                        <li><strong>Resend</strong> &mdash; email delivery service. Receives your email address to send authentication and notification emails.</li>
                        <li><strong>OpenAI</strong> &mdash; used to process and structure medical topic data. No user personal data is sent to OpenAI.</li>
                    </ul>
                    <h5 class="fw-semibold mt-4">Data Location</h5>
                    <p>Data is stored in the United States via Railway (hosting) and Resend (email). By using the service, you consent to this transfer.</p>
                    <h5 class="fw-semibold mt-4">Your Rights</h5>
                    <p>You have the right to:</p>
                    <ul>
                        <li><strong>Access</strong> your data via the dashboard.</li>
                        <li><strong>Delete</strong> your account and all associated data from the dashboard settings.</li>
                        <li><strong>Data portability</strong> &mdash; contact us to request an export of your data.</li>
                    </ul>
                    <h5 class="fw-semibold mt-4">Contact</h5>
                    <p>For privacy-related requests, email <a href="mailto:@_contactEmail">@_contactEmail</a>.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" id="privacyConfirmBtn" class="btn btn-primary" disabled @onclick="ConfirmPrivacy">I've read this</button>
                </div>
            </div>
        </div>
    </div>
}

@* Terms of Service Modal *@
@if (_showTermsModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Terms of Service</h5>
                    <button type="button" class="btn-close" @onclick="CloseTermsModal"></button>
                </div>
                <div class="modal-body" id="termsModalBody" style="overflow-y: auto; max-height: 60vh;">
                    <p class="text-muted">Last updated: 2 March 2026</p>
                    <hr>
                    <h5 class="fw-semibold">Acceptable Use</h5>
                    <p>You agree to use Meducate API for lawful purposes only. You must not:</p>
                    <ul>
                        <li>Attempt to circumvent rate limits or authentication.</li>
                        <li>Share, publish, or expose your API keys.</li>
                        <li>Use the service to build products that provide medical diagnoses or treatment recommendations.</li>
                        <li>Resell API access without prior written consent.</li>
                    </ul>
                    <h5 class="fw-semibold mt-4">Rate Limits</h5>
                    <p>Each API key has a daily request limit. Exceeding this limit will result in <code>429 Too Many Requests</code> responses until the limit resets at midnight UTC. Limits may be adjusted at our discretion.</p>
                    <h5 class="fw-semibold mt-4">API Key Security</h5>
                    <p>You are responsible for keeping your API keys secure. If you believe a key has been compromised, disable it immediately from your dashboard. We are not liable for unauthorised usage resulting from exposed keys.</p>
                    <h5 class="fw-semibold mt-4">Medical Disclaimer</h5>
                    <p><strong>Meducate API is for educational and informational purposes only.</strong> The data provided does not constitute medical advice, diagnosis, or treatment. Always consult a qualified healthcare professional for medical decisions. We make no warranties about the accuracy, completeness, or timeliness of the medical information provided.</p>
                    <h5 class="fw-semibold mt-4">Liability Limitations</h5>
                    <p>Meducate API is provided "as is" without warranties of any kind, express or implied. To the fullest extent permitted by law, we shall not be liable for any indirect, incidental, or consequential damages arising from your use of the service.</p>
                    <h5 class="fw-semibold mt-4">Account Termination</h5>
                    <p>We reserve the right to suspend or terminate accounts that violate these terms or abuse the service. You may delete your account at any time from the dashboard, which permanently removes all your data.</p>
                    <h5 class="fw-semibold mt-4">Changes to Terms</h5>
                    <p>We may update these terms from time to time. Continued use of the service after changes constitutes acceptance of the updated terms.</p>
                    <h5 class="fw-semibold mt-4">Contact</h5>
                    <p>For questions about these terms, email <a href="mailto:@_contactEmail">@_contactEmail</a>.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" id="termsConfirmBtn" class="btn btn-primary" disabled @onclick="ConfirmTerms">I've read this</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string _contactEmail = string.Concat("will", "@", "meducateapi.com");

    private bool _isLoading = true;
    private bool _isCreateMode;

    private bool _hasViewedPrivacy;
    private bool _hasViewedTerms;
    private bool _showPrivacyModal;
    private bool _showTermsModal;

    private IJSObjectReference? _jsModule;

    [SupplyParameterFromQuery(Name = "mode")]
    private string? Mode { get; set; }

    private sealed record UserRegistrationRequestForm
    {
        public string Username { get; set; } = "";
        public bool AcceptedTerms { get; set; }
        public string? Website { get; set; }
        public string Timestamp { get; set; } = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds().ToString();
    }

    [SupplyParameterFromForm]
    private UserRegistrationRequestForm? _form { get; set; }

    protected override void OnParametersSet()
    {
        _isCreateMode = Mode is null || string.Equals(Mode, "create", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnInitializedAsync()
    {
        _form ??= new();

        // Check if cookie exists before making API call
        var hasCookie = HttpContextAccessor.HttpContext?.Request.Cookies.ContainsKey("meducateapi_auth") ?? false;

        if (!hasCookie)
        {
            // No cookie = not authenticated, show the form
            _isLoading = false;
            return;
        }

        var userStatus = await Api.GetUserStatusAsync();

        if (userStatus is not null && userStatus.IsEmailVerified)
        {
            if (userStatus.OrganisationId is not null)
            {
                if (userStatus.HasApiKeys)
                    Nav.NavigateTo("/dashboard", replace: true);
                else
                    Nav.NavigateTo($"/api-key?orgId={userStatus.OrganisationId}", replace: true);
            }
            else
            {
                Nav.NavigateTo("/create-organisation", replace: true);
            }

            return;
        }

        _isLoading = false;
    }

    private async Task EnsureJsModule()
    {
        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import",
            "./Components/Pages/Register.razor.js");
    }

    private async Task OpenPrivacyModal()
    {
        _showPrivacyModal = true;
        StateHasChanged();
        await Task.Yield();
        await EnsureJsModule();
        await _jsModule!.InvokeVoidAsync("initScrollCheck", "privacyModalBody", "privacyConfirmBtn");
    }

    private void ClosePrivacyModal() => _showPrivacyModal = false;

    private void ConfirmPrivacy()
    {
        _hasViewedPrivacy = true;
        _showPrivacyModal = false;
    }

    private async Task OpenTermsModal()
    {
        _showTermsModal = true;
        StateHasChanged();
        await Task.Yield();
        await EnsureJsModule();
        await _jsModule!.InvokeVoidAsync("initScrollCheck", "termsModalBody", "termsConfirmBtn");
    }

    private void CloseTermsModal() => _showTermsModal = false;

    private void ConfirmTerms()
    {
        _hasViewedTerms = true;
        _showTermsModal = false;
    }

    private bool _isSubmitting;

    public string? Alert { get; set; }
    public string AlertCss { get; set; } = "alert-info";
    private bool _isCompleted;

    private bool IsCompleted => _isCompleted;

    private async Task Submit()
    {
        if (_form is null || _isSubmitting)
            return;

        _isSubmitting = true;

        try
        {
            var response = await Api.RegisterUserAsync(
                _form.Username,
                _isCreateMode ? "create" : "signin",
                _isCreateMode ? "2026-03-02" : null,
                _form.Website,
                _form.Timestamp);

            Alert = response.Message;
            AlertCss = response.IsSuccess ? "alert-success" : "alert-danger";
            _isCompleted = response.IsSuccess;
        }
        catch
        {
            Alert = "Unable to register at this time. Please try again later.";
            AlertCss = "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
