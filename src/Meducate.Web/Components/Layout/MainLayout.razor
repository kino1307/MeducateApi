@inherits LayoutComponentBase

<Header @rendermode="InteractiveServer" />

<div class="page d-flex flex-column min-vh-100">
    <main class="flex-grow-1">
        <article class="content px-4">
            @Body
        </article>
    </main>
    <footer class="border-top py-3 mt-auto">
        <div class="container text-center text-muted small">
            <span>&copy; @DateTime.UtcNow.Year Meducate API. For educational and informational purposes only.</span>
            <br />
            <a href="/privacy" class="text-muted">Privacy</a>
            <span class="mx-1">&middot;</span>
            <a href="/terms" class="text-muted">Terms</a>
            <span class="mx-1">&middot;</span>
            <a href="mailto:@_contactEmail" class="text-muted">@_contactEmail</a>
        </div>
    </footer>
</div>

<Meducate.Web.Components.Shared.CookieNotice @rendermode="InteractiveServer" />
<Meducate.Web.Components.Shared.ToastContainer @rendermode="InteractiveServer" />

@code {
    private static readonly string _contactEmail = string.Concat("will", "@", "meducateapi.com");
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>